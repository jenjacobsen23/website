# Resend: https://resend.com — API sends contact form emails (FROM must be a verified sender/domain in production).
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=noreply@resend.dev

# Optional: Resend audience/segment ID if you later wire marketing syncs.
RESEND_SEGMENT_ID=

# Inbox for form submissions (and footer mailto). Required for /api/contact.
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# Optional: override recipient server-side only (hides inbox from public bundle).
# CONTACT_EMAIL=

# Optional: Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
